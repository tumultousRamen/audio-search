# LanceDB — local, no key needed
LANCEDB_PATH=./data/lancedb

# Logical table names (rarely overridden)
TABLE_TEXT=clips_text
TABLE_AUDIO=clips_audio

# Models
TEXT_ENCODER=BAAI/bge-small-en-v1.5
AUDIO_ENCODER=laion/clap-htsat-unfused

# Anthropic — optional (only for LLM-as-judge stretch eval)
ANTHROPIC_API_KEY=

# Runtime
DEVICE=mps           # mps | cuda | cpu — auto-detected if unset
HF_HOME=./.cache/huggingface
